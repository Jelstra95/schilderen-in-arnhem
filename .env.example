# Supabase — Project Settings > API
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only service-role key (NEVER expose to the client / commit).
# Used for admin operations: creating participant accounts, streaming private files.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket that holds the protected course materials (created in the migration).
SUPABASE_MATERIALS_BUCKET=course-materials
